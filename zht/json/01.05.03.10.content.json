"content": "<style>\nh1.thlex-title { font-size: 1.3em; margin: 0 0 0.4em; }\n.thlex-key { color: #888; font-size: 0.85em; font-weight: normal; margin-right: 0.4em; }\nnav.thlex-index { margin: 0.5em 0 0.75em; }\nnav.thlex-index ul { margin: 0; padding-left: 1.2em; }\nnav.thlex-index li { margin: 0.15em 0; font-size: 0.95em; }\n.thlex-section { margin: 0.6em 0; }\nh2.thlex-heading { font-size: 1em; margin: 0.5em 0 0.2em; }\nh3.thlex-subheading { font-size: 0.95em; font-weight: normal; font-style: italic; margin: 0.2em 0; }\n.thlex-language-sets { margin: 0.3em 0 0.3em 1em; }\n.thlex-language-set { margin: 0.4em 0; padding-left: 0.75em; border-left: 3px solid #e0e0e0; }\n.thlex-language { font-size: 0.8em; color: #888; margin-right: 0.4em; }\n.thlex-lemma { font-weight: bold; font-family: serif; }\n.thlex-translit { color: #555; font-style: italic; font-size: 0.9em; margin-left: 0.3em; }\n.thlex-refs { font-size: 0.85em; color: #444; margin-top: 0.15em; }\n.thlex-paragraphs p { margin: 0.35em 0; font-size: 0.95em; line-height: 1.5; }\n.thlex-image { margin: 0.5em 0; display: block; }\n.thlex-image img { max-width: 100%; height: auto; display: block; }\nfigcaption.thlex-caption { font-size: 0.85em; color: #555; font-style: italic; margin-top: 0.2em; }\n.thlex-abbr { border-bottom: 1px dotted #888; cursor: help; }\n.thlex-xref { color: #1a5fb4; }\nspan[data-bnType=\"bibleReference\"] { color: #1a5fb4; }\ntable.thlex-table { border-collapse: collapse; font-size: 0.9em; margin: 0.5em 0; }\ntable.thlex-table td { padding: 0.2em 0.6em; vertical-align: top; border: 1px solid #ddd; }\ntable.thlex-table tr:first-child td { font-weight: bold; background: #f5f5f5; }\nul.thlex-index-list { margin: 0.4em 0; padding-left: 1.4em; font-size: 0.95em; line-height: 1.6; }\nul.thlex-index-list ul { margin: 0.1em 0; padding-left: 1.4em; }\n.thlex-index-key { font-weight: bold; font-style: italic; }\n</style><h1 class=\"thlex-title\" id=\"REALIA:1.5.3.10\"><span class=\"thlex-key\">1.5.3.10</span> 標題：紫色布（purple cloth）</h1><div class=\"thlex-section\">\n<h2 class=\"thlex-heading\">經文出處</h2>\n<div class=\"thlex-language-sets\">\n<div class=\"thlex-language-set\">\n<span class=\"thlex-language\">Hebrew</span> <span class=\"thlex-lemma\">來： אַרְגְּוָן</span> <span class=\"thlex-translit\">(音譯： ’argewan)</span>\n<div class=\"thlex-refs\"><a href=\"https://ref.ly/2Chr2:6\">2CH 2:6</a>, <a href=\"https://ref.ly/Dan5:7\">DAN 5:7</a>, <a href=\"https://ref.ly/Dan5:16\">DAN 5:16</a>, <a href=\"https://ref.ly/Dan5:29\">DAN 5:29</a></div>\n</div>\n<div class=\"thlex-language-set\">\n<span class=\"thlex-language\">Hebrew</span> <span class=\"thlex-lemma\">來： אַרְגָּמָן</span> <span class=\"thlex-translit\">(音譯： ’argaman)</span>\n<div class=\"thlex-refs\"><a href=\"https://ref.ly/Exod25:4\">EXO 25:4</a>, <a href=\"https://ref.ly/Exod26:1\">EXO 26:1</a>, <a href=\"https://ref.ly/Exod26:31\">EXO 26:31</a>, <a href=\"https://ref.ly/Exod26:36\">EXO 26:36</a>, <a href=\"https://ref.ly/Exod27:16\">EXO 27:16</a>, <a href=\"https://ref.ly/Exod28:6\">EXO 28:6</a>, <a href=\"https://ref.ly/Exod28:8\">EXO 28:8</a>, <a href=\"https://ref.ly/Exod28:15\">EXO 28:15</a>, <a href=\"https://ref.ly/Exod28:33\">EXO 28:33</a>, <a href=\"https://ref.ly/Exod35:6\">EXO 35:6</a>, <a href=\"https://ref.ly/Exod35:23\">EXO 35:23</a>, <a href=\"https://ref.ly/Exod35:25\">EXO 35:25</a>, <a href=\"https://ref.ly/Exod35:35\">EXO 35:35</a>, <a href=\"https://ref.ly/Exod36:8\">EXO 36:8</a>, <a href=\"https://ref.ly/Exod36:35\">EXO 36:35</a>, <a href=\"https://ref.ly/Exod36:37\">EXO 36:37</a>, <a href=\"https://ref.ly/Exod38:18\">EXO 38:18</a>, <a href=\"https://ref.ly/Exod38:23\">EXO 38:23</a>, <a href=\"https://ref.ly/Exod39:3\">EXO 39:3</a>, <a href=\"https://ref.ly/Exod39:8\">EXO 39:8</a>, <a href=\"https://ref.ly/Exod39:24\">EXO 39:24</a>, <a href=\"https://ref.ly/Exod39:29\">EXO 39:29</a>, <a href=\"https://ref.ly/Num4:13\">NUM 4:13</a>, <a href=\"https://ref.ly/Judg8:26\">JDG 8:26</a>, <a href=\"https://ref.ly/2Chr2:13\">2CH 2:13</a>, <a href=\"https://ref.ly/2Chr3:14\">2CH 3:14</a>, <a href=\"https://ref.ly/Esth1:6\">EST 1:6</a>, <a href=\"https://ref.ly/Esth8:15\">EST 8:15</a>, <a href=\"https://ref.ly/Prov31:22\">PRO 31:22</a>, <a href=\"https://ref.ly/Song3:10\">SNG 3:10</a>, <a href=\"https://ref.ly/Song7:6\">SNG 7:6</a>, <a href=\"https://ref.ly/Jer10:9\">JER 10:9</a>, <a href=\"https://ref.ly/Ezek27:7\">EZK 27:7</a>, <a href=\"https://ref.ly/Ezek27:16\">EZK 27:16</a></div>\n</div>\n<div class=\"thlex-language-set\">\n<span class=\"thlex-language\">Hebrew</span> <span class=\"thlex-lemma\">來： חָמוּץ</span> <span class=\"thlex-translit\">(音譯： chamuts)</span>\n<div class=\"thlex-refs\"><a href=\"https://ref.ly/Isa63:1\">ISA 63:1</a></div>\n</div>\n<div class=\"thlex-language-set\">\n<span class=\"thlex-language\">Hebrew</span> <span class=\"thlex-lemma\">來： כַּרְמִיל</span> <span class=\"thlex-translit\">(音譯： karmil)</span>\n<div class=\"thlex-refs\"><a href=\"https://ref.ly/2Chr2:6\">2CH 2:6</a>, <a href=\"https://ref.ly/2Chr2:13\">2CH 2:13</a>, <a href=\"https://ref.ly/2Chr3:14\">2CH 3:14</a></div>\n</div>\n<div class=\"thlex-language-set\">\n<span class=\"thlex-language\">Hebrew</span> <span class=\"thlex-lemma\">來： שָׁנִי</span> <span class=\"thlex-translit\">(音譯： shani)</span>\n<div class=\"thlex-refs\"><a href=\"https://ref.ly/Gen38:28\">GEN 38:28</a>, <a href=\"https://ref.ly/Gen38:30\">GEN 38:30</a>, <a href=\"https://ref.ly/Josh2:18\">JOS 2:18</a>, <a href=\"https://ref.ly/Josh2:21\">JOS 2:21</a>, <a href=\"https://ref.ly/2Sam1:24\">2SA 1:24</a>, <a href=\"https://ref.ly/Prov31:21\">PRO 31:21</a>, <a href=\"https://ref.ly/Song4:3\">SNG 4:3</a>, <a href=\"https://ref.ly/Isa1:18\">ISA 1:18</a>, <a href=\"https://ref.ly/Jer4:30\">JER 4:30</a></div>\n</div>\n<div class=\"thlex-language-set\">\n<span class=\"thlex-language\">Hebrew</span> <span class=\"thlex-lemma\">來： תלע</span> <span class=\"thlex-translit\">(音譯： tala‘)</span>\n<div class=\"